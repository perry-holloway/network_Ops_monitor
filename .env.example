APP_HOST=0.0.0.0
APP_PORT=8090
DATA_PATH=/data/ops-console.db

# Format:
# WATCHED_DEVICES=ip=name[:sensitivity[:ports]]
# Ports are optional comma-delimited TCP ports used as a fallback if ICMP ping fails.
WATCHED_DEVICES=192.168.1.1=UDM Gateway:critical:443,80;192.168.1.245=Main AP U6+:high:443;192.168.1.43=USW Flex Mini:high:443;192.168.1.20=Storage NAS:critical:443,445

CHECK_INTERVAL_SECONDS=60
HISTORY_LIMIT=100

# Optional known infrastructure inventory.
# Format: ip=name:role[:expected_uplink]
# Roles: gateway, switch, access_point, server, storage, other
INFRASTRUCTURE_DEVICES=192.168.1.1=UDM Gateway:gateway;192.168.1.43=USW Flex Mini:switch:UDM Gateway;192.168.1.245=Main AP U6+:access_point:USW Flex Mini

WAN_TARGETS=1.1.1.1=Cloudflare DNS;8.8.8.8=Google DNS
DNS_LOOKUPS=ui.com;github.com
HTTP_CHECKS=https://ui.com=UniFi Website;https://github.com=GitHub

# Optional LAN discovery.
# Scans configured subnets with ping and a few quick TCP probes to find reachable devices.
LAN_DISCOVERY_ENABLED=false
LAN_DISCOVERY_SUBNETS=192.168.1.0/24
LAN_DISCOVERY_PORTS=22,53,80,443,445,8080,8443
LAN_DISCOVERY_MAX_HOSTS=256

# Optional manual WAN speed test.
# The dashboard only runs this when you click "Run speed test".
SPEED_TEST_ENABLED=true
SPEED_TEST_DOWNLOAD_URL=https://speed.cloudflare.com/__down?bytes=10000000
SPEED_TEST_UPLOAD_ENABLED=false
SPEED_TEST_UPLOAD_URL=https://speed.cloudflare.com/__up
SPEED_TEST_DOWNLOAD_BYTES=10000000
SPEED_TEST_UPLOAD_BYTES=1000000
SPEED_TEST_TIMEOUT_SECONDS=20
SPEED_TEST_MIN_DOWNLOAD_MBPS=100
SPEED_TEST_MIN_UPLOAD_MBPS=10

# Optional local UniFi Network API collector.
# This needs a Network Integration API key, not the Site Manager key.
UNIFI_API_ENABLED=false
UNIFI_API_BASE_URL=https://192.168.1.1/proxy/network/integration
UNIFI_API_KEY=
UNIFI_SITE_ID=
UNIFI_VERIFY_TLS=false
UNIFI_TIMEOUT_SECONDS=10
UNIFI_LEGACY_STATS_ENABLED=true

# Optional account-wide Site Manager API collector.
# This works with keys created at https://unifi.ui.com/settings/api-keys.
UNIFI_SITE_MANAGER_ENABLED=false
UNIFI_SITE_MANAGER_BASE_URL=https://api.ui.com
UNIFI_SITE_MANAGER_API_KEY=

# Optional guarded UniFi operation requests.
# Keep disabled unless you are intentionally testing write-action workflows during a maintenance window.
UNIFI_WRITE_ACTIONS_ENABLED=false
UNIFI_WRITE_ACTIONS_CONFIRMATION=APPLY

# Optional trusted/watched client labels shown on the Clients page.
# Format: mac=name[:category];mac=name[:category]
# Keep real MAC addresses in local .env only.
TRUSTED_CLIENTS=
