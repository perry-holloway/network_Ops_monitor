APP_HOST=0.0.0.0
APP_PORT=8090
DATA_PATH=/data/ops-console.db

# Format:
# WATCHED_DEVICES=ip=name[:sensitivity[:ports]]
# Ports are optional comma-delimited TCP ports used as a fallback if ICMP ping fails.
WATCHED_DEVICES=192.168.1.1=UDM Gateway:critical:443,80;192.168.1.20=Storage NAS:critical:443,445;192.168.1.50=Main AP:high:443

CHECK_INTERVAL_SECONDS=60
HISTORY_LIMIT=100

WAN_TARGETS=1.1.1.1=Cloudflare DNS;8.8.8.8=Google DNS
DNS_LOOKUPS=ui.com;github.com
HTTP_CHECKS=https://ui.com=UniFi Website;https://github.com=GitHub

# Optional local UniFi Network API collector.
# This needs a Network Integration API key, not the Site Manager key.
UNIFI_API_ENABLED=false
UNIFI_API_BASE_URL=https://192.168.1.1/proxy/network/integration
UNIFI_API_KEY=
UNIFI_SITE_ID=
UNIFI_VERIFY_TLS=false
UNIFI_TIMEOUT_SECONDS=10
UNIFI_LEGACY_STATS_ENABLED=true

# Optional account-wide Site Manager API collector.
# This works with keys created at https://unifi.ui.com/settings/api-keys.
UNIFI_SITE_MANAGER_ENABLED=false
UNIFI_SITE_MANAGER_BASE_URL=https://api.ui.com
UNIFI_SITE_MANAGER_API_KEY=
